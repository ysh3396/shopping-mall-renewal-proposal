// Prisma schema for 더본투비 쇼핑몰 (PostgreSQL / Supabase)
// PostgreSQL features: enums, @db.Text, Json type

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum RestrictionMode {
  NONE
  RESTRICTED
  MAINTENANCE
}

enum OrderStatus {
  PENDING
  AWAITING_DEPOSIT
  PAID
  PREPARING
  SHIPPED
  DELIVERED
  CANCELLED
  RETURN_REQUESTED
  RETURNED
  EXCHANGE_REQUESTED
  EXCHANGED
}

enum PaymentMethod {
  BANK_TRANSFER
  KAKAOPAY
  TOSSPAY
  CARD
}

enum PaymentStatus {
  PENDING
  AWAITING_DEPOSIT
  COMPLETED
  FAILED
  CANCELLED
  REFUNDED
  PARTIAL_REFUNDED
}

enum ShipmentStatus {
  PENDING
  PICKED_UP
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  FAILED
}

enum RefundStatus {
  PENDING
  COMPLETED
  REJECTED
}

enum ReturnStatus {
  REQUESTED
  APPROVED
  REJECTED
  COMPLETED
}

enum ExchangeStatus {
  REQUESTED
  APPROVED
  REJECTED
  COMPLETED
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum InventoryReason {
  ORDER
  RESTOCK
  ADJUSTMENT
  RETURN
}

enum ProductRequestStatus {
  PENDING
  REVIEWED
  SOURCED
  REJECTED
}

enum BannerPosition {
  HERO
  MIDDLE
  SIDEBAR
}

enum PromotionType {
  BULK_DISCOUNT
  BUNDLE
  FREE_SHIPPING
}

// ─────────────────────────────────────────────
// Site & Config
// ─────────────────────────────────────────────

model SiteConfig {
  id                     String          @id @default(cuid())
  siteName               String
  domain                 String?
  logoUrl                String?
  businessName           String?
  businessNumber         String?
  ceoName                String?
  address                String?
  phone                  String?
  email                  String?
  bankName               String?
  bankAccount            String?
  bankHolder             String?
  freeShippingThreshold  Int             @default(50000)
  defaultShippingFee     Int             @default(2500)
  returnShippingFee      Int             @default(3000)
  restrictionMode        RestrictionMode @default(NONE)
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
}

// ─────────────────────────────────────────────
// Admin & RBAC
// ─────────────────────────────────────────────

model AdminUser {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String
  passwordHash  String
  roleId        String
  role          Role           @relation(fields: [roleId], references: [id])
  isActive      Boolean        @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime       @default(now())
  auditLogs     AuditLog[]
  notifications Notification[]
}

model Role {
  id          String           @id @default(cuid())
  // values: "super_admin" | "manager" | "staff"
  name        String           @unique
  adminUsers  AdminUser[]
  permissions RolePermission[]
}

model Permission {
  id       String           @id @default(cuid())
  resource String
  action   String
  roles    RolePermission[]

  @@unique([resource, action])
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
}

// ─────────────────────────────────────────────
// Customer
// ─────────────────────────────────────────────

model Customer {
  id                  String          @id @default(cuid())
  email               String          @unique
  name                String
  phone               String?
  // OAuth provider e.g. "kakao" | "naver" | "google" | "local"
  provider            String?
  providerId          String?
  ageVerified         Boolean         @default(false)
  ageVerifiedAt       DateTime?
  ageVerifyMethod     String?
  ageVerifyCI         String?
  ageVerifyExpiresAt  DateTime?
  gradeId             String?
  grade               CustomerGrade?  @relation(fields: [gradeId], references: [id])
  orders              Order[]
  addresses           Address[]
  cart                Cart?
  reviews             Review[]
  qnas                QnA[]
  productRequests     ProductRequest[]
  couponUsages        CouponUsage[]
  deletedAt           DateTime?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@unique([provider, providerId])
}

model CustomerGrade {
  id              String     @id @default(cuid())
  name            String
  minOrderAmount  Int        @default(0)
  discountRate    Float      @default(0)
  customers       Customer[]
}

model Address {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  label      String?
  recipient  String
  phone      String
  zipCode    String
  address1   String
  address2   String?
  isDefault  Boolean  @default(false)
}

// ─────────────────────────────────────────────
// Category
// ─────────────────────────────────────────────

model Category {
  id           String     @id @default(cuid())
  name         String
  slug         String     @unique
  parentId     String?
  parent       Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children     Category[] @relation("CategoryTree")
  sortOrder    Int        @default(0)
  isActive     Boolean    @default(true)
  isRestricted Boolean    @default(false)
  products     Product[]
}

// ─────────────────────────────────────────────
// Product
// ─────────────────────────────────────────────

model Product {
  id           String           @id @default(cuid())
  name         String
  slug         String           @unique
  description  String?          @db.Text
  detailHtml   String?          @db.Text
  categoryId   String?
  category     Category?        @relation(fields: [categoryId], references: [id])
  basePrice    Int
  comparePrice Int?
  costPrice    Int?
  // comma-separated: "SALE,BEST,HOT,NEW"
  badges       String?
  isActive     Boolean          @default(true)
  isAdult      Boolean          @default(true)
  isRestricted Boolean          @default(false)
  sortOrder    Int              @default(0)
  deletedAt    DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  images       ProductImage[]
  options      ProductOption[]
  variants     ProductVariant[]
  orderItems   OrderItem[]
  reviews      Review[]
  qnas         QnA[]
  collections  Collection[]     @relation("CollectionProducts")
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  alt       String?
  sortOrder Int     @default(0)
}

model ProductOption {
  id        String               @id @default(cuid())
  productId String
  product   Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  // e.g. "니코틴 함량" | "용량"
  name      String
  sortOrder Int                  @default(0)
  values    ProductOptionValue[]
}

model ProductOptionValue {
  id           String               @id @default(cuid())
  optionId     String
  option       ProductOption        @relation(fields: [optionId], references: [id], onDelete: Cascade)
  // e.g. "9.8mg" | "20mg"
  value        String
  sortOrder    Int                  @default(0)
  variantLinks VariantOptionValue[]
}

model ProductVariant {
  id            String               @id @default(cuid())
  productId     String
  product       Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku           String?              @unique
  price         Int
  stock         Int                  @default(0)
  isActive      Boolean              @default(true)
  optionValues  VariantOptionValue[]
  orderItems    OrderItem[]
  cartItems     CartItem[]
  inventoryLogs InventoryLog[]
}

model VariantOptionValue {
  variantId     String
  optionValueId String
  variant       ProductVariant     @relation(fields: [variantId], references: [id], onDelete: Cascade)
  optionValue   ProductOptionValue @relation(fields: [optionValueId], references: [id], onDelete: Cascade)

  @@id([variantId, optionValueId])
}

model InventoryLog {
  id          String          @id @default(cuid())
  variantId   String
  variant     ProductVariant  @relation(fields: [variantId], references: [id])
  delta       Int
  reason      InventoryReason
  referenceId String?
  createdAt   DateTime        @default(now())
}

// ─────────────────────────────────────────────
// Cart
// ─────────────────────────────────────────────

model Cart {
  id         String     @id @default(cuid())
  customerId String     @unique
  customer   Customer   @relation(fields: [customerId], references: [id])
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  items      CartItem[]
}

model CartItem {
  id        String         @id @default(cuid())
  cartId    String
  cart      Cart           @relation(fields: [cartId], references: [id])
  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id])
  quantity  Int

  @@unique([cartId, variantId])
}

// ─────────────────────────────────────────────
// Order
// ─────────────────────────────────────────────

model Order {
  id              String           @id @default(cuid())
  orderNumber     String           @unique
  customerId      String
  customer        Customer         @relation(fields: [customerId], references: [id])
  status          OrderStatus
  subtotal        Int
  shippingFee     Int              @default(2500)
  discountAmount  Int              @default(0)
  totalAmount     Int
  shippingAddress Json
  note            String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  items           OrderItem[]
  payment         Payment?
  shipment        Shipment?
  refund          Refund?
  returnRequest   ReturnRequest?
  exchangeRequest ExchangeRequest?
}

model OrderItem {
  id          String          @id @default(cuid())
  orderId     String
  order       Order           @relation(fields: [orderId], references: [id])
  productId   String
  product     Product         @relation(fields: [productId], references: [id])
  variantId   String?
  variant     ProductVariant? @relation(fields: [variantId], references: [id])
  // snapshots at time of order
  productName String
  variantName String?
  price       Int
  quantity    Int
  subtotal    Int
}

// ─────────────────────────────────────────────
// Payment
// ─────────────────────────────────────────────

model Payment {
  id                 String        @id @default(cuid())
  orderId            String        @unique
  order              Order         @relation(fields: [orderId], references: [id])
  method             PaymentMethod
  amount             Int
  status             PaymentStatus
  bankName           String?
  accountNumber      String?
  depositorName      String?
  depositDeadline    DateTime?
  depositConfirmedAt DateTime?
  depositConfirmedBy String?
  pgProvider         String?
  pgTxId             String?
  // JSON PG raw response
  rawResponse        String?
  paidAt             DateTime?
  createdAt          DateTime      @default(now())
}

// ─────────────────────────────────────────────
// Shipment
// ─────────────────────────────────────────────

model Shipment {
  id             String         @id @default(cuid())
  orderId        String         @unique
  order          Order          @relation(fields: [orderId], references: [id])
  carrier        String         @default("로젠택배")
  trackingNumber String?
  status         ShipmentStatus
  shippedAt      DateTime?
  deliveredAt    DateTime?
  // JSON raw tracking data
  rawTracking    String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

// ─────────────────────────────────────────────
// Refund / Return / Exchange
// ─────────────────────────────────────────────

model Refund {
  id            String       @id @default(cuid())
  orderId       String       @unique
  order         Order        @relation(fields: [orderId], references: [id])
  amount        Int
  reason        String?
  refundMethod  String?
  refundAccount String?
  status        RefundStatus
  processedAt   DateTime?
  createdAt     DateTime     @default(now())
}

model ReturnRequest {
  id           String       @id @default(cuid())
  orderId      String       @unique
  order        Order        @relation(fields: [orderId], references: [id])
  reason       String
  detailReason String?
  status       ReturnStatus
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model ExchangeRequest {
  id           String         @id @default(cuid())
  orderId      String         @unique
  order        Order          @relation(fields: [orderId], references: [id])
  reason       String
  newVariantId String?
  status       ExchangeStatus
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

// ─────────────────────────────────────────────
// Coupon & Promotion
// ─────────────────────────────────────────────

model Coupon {
  id             String        @id @default(cuid())
  code           String        @unique
  name           String
  discountType   DiscountType
  discountValue  Int
  minOrderAmount Int?
  maxDiscount    Int?
  usageLimit     Int?
  usedCount      Int           @default(0)
  startsAt       DateTime?
  expiresAt      DateTime?
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  usages         CouponUsage[]
}

model CouponUsage {
  id         String   @id @default(cuid())
  couponId   String
  coupon     Coupon   @relation(fields: [couponId], references: [id])
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  orderId    String?
  usedAt     DateTime @default(now())
}

model Promotion {
  id        String        @id @default(cuid())
  name      String
  type      PromotionType
  config    Json
  startsAt  DateTime?
  expiresAt DateTime?
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())
}

// ─────────────────────────────────────────────
// CMS
// ─────────────────────────────────────────────

model Banner {
  id        String         @id @default(cuid())
  title     String
  imageUrl  String
  linkUrl   String?
  position  BannerPosition
  sortOrder Int            @default(0)
  isActive  Boolean        @default(true)
  startsAt  DateTime?
  expiresAt DateTime?
}

model Popup {
  id          String    @id @default(cuid())
  title       String
  imageUrl    String?
  contentHtml String?   @db.Text
  linkUrl     String?
  showOnce    Boolean   @default(false)
  isActive    Boolean   @default(true)
  startsAt    DateTime?
  expiresAt   DateTime?
}

model Collection {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  products    Product[] @relation("CollectionProducts")
}

model PageContent {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  contentHtml String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─────────────────────────────────────────────
// Review & QnA
// ─────────────────────────────────────────────

model Review {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  // 1-5
  rating     Int
  content    String?
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model QnA {
  id         String    @id @default(cuid())
  customerId String
  customer   Customer  @relation(fields: [customerId], references: [id])
  productId  String
  product    Product   @relation(fields: [productId], references: [id])
  question   String
  answer     String?
  isPublic   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  answeredAt DateTime?
}

// ─────────────────────────────────────────────
// Product Request
// ─────────────────────────────────────────────

model ProductRequest {
  id          String               @id @default(cuid())
  customerId  String
  customer    Customer             @relation(fields: [customerId], references: [id])
  productName String
  description String?
  status      ProductRequestStatus @default(PENDING)
  adminNote   String?
  createdAt   DateTime             @default(now())
}

// ─────────────────────────────────────────────
// Notification & Audit
// ─────────────────────────────────────────────

model Notification {
  id            String     @id @default(cuid())
  type          String
  title         String
  message       String
  isRead        Boolean    @default(false)
  adminUserId   String?
  adminUser     AdminUser? @relation(fields: [adminUserId], references: [id])
  referenceType String?
  referenceId   String?
  createdAt     DateTime   @default(now())
}

model AuditLog {
  id          String    @id @default(cuid())
  adminUserId String
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id])
  action      String
  resource    String
  resourceId  String?
  details     String?   @db.Text
  ipAddress   String?
  createdAt   DateTime  @default(now())
}

// ─────────────────────────────────────────────
// SEO / Redirect
// ─────────────────────────────────────────────

model RedirectRule {
  id         String   @id @default(cuid())
  sourcePath String   @unique
  targetPath String
  statusCode Int      @default(301)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
}
